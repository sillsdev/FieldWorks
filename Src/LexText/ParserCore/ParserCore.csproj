<?xml version='1.0' encoding='utf-8'?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>ParserCore</AssemblyName>
    <RootNamespace>SIL.FieldWorks.WordWorks.Parser</RootNamespace>
    <TargetFramework>net48</TargetFramework>
    <OutputType>Library</OutputType>    <NoWarn>168,169,219,414,649,1635,1702,1701</NoWarn>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <Prefer32Bit>false</Prefer32Bit>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|x64' ">
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <DebugSymbols>true</DebugSymbols>
    <Optimize>false</Optimize>
    <DebugType>portable</DebugType>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|x64' ">
    <DefineConstants>TRACE</DefineConstants>
    <DebugSymbols>true</DebugSymbols>
    <Optimize>true</Optimize>
    <DebugType>portable</DebugType>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="CommonServiceLocator" Exclude="Build,Analyzers" />
    <PackageReference Include="Newtonsoft.Json" />
    <PackageReference Include="SIL.Core" />
    <PackageReference Include="SIL.LCModel" />
    <PackageReference Include="SIL.LCModel.Core" GeneratePathProperty="true" />
    <PackageReference Include="SIL.LCModel.Utils" />
    <PackageReference Include="SIL.Machine" />
    <PackageReference Include="SIL.Machine.Morphology.HermitCrab" />
    <PackageReference Include="SIL.WritingSystems" />
    <PackageReference Include="System.ValueTuple" />
    <PackageReference Include="SIL.Paradigm.GAFAWSAnalysis" />
  </ItemGroup>
  <ItemGroup>
    <Reference Include="ApplicationTransforms" Condition="Exists('$(dir-outputBase)\\ApplicationTransforms.dll')">
      <HintPath>$(dir-outputBase)\\ApplicationTransforms.dll</HintPath>
    </Reference>
    <Reference Include="System.Xml.Linq" />
    <Reference Include="netstandard" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="../../Utilities/XMLUtils/XMLUtils.csproj" />
    <ProjectReference Include="../../XCore/xCoreInterfaces/xCoreInterfaces.csproj" />
    <ProjectReference Include="XAmpleManagedWrapper/XAmpleManagedWrapper.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="ParserCoreTests/**" />
    <None Remove="ParserCoreTests/**" />
    <Compile Remove="XAmpleManagedWrapper/**" />
    <None Remove="XAmpleManagedWrapper/**" />
    <Compile Include="..\..\CommonAssemblyInfo.cs">
      <Link>Properties\CommonAssemblyInfo.cs</Link>
    </Compile>
  </ItemGroup>
</Project>