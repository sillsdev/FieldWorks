<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FwAvaloniaDialogs"
             xmlns:res="clr-namespace:FwAvaloniaDialogs"
             x:Class="FwAvaloniaDialogs.DateRangeFilterDialogView"
             x:DataType="vm:DateRangeFilterDialogViewModel"
             Classes="fwDialogRoot"
             MinWidth="360" MinHeight="220">
	<!-- The browse "Restrict Date…" date-range dialog — the Avalonia counterpart of the legacy SimpleDateMatchDlg
	     the FilterBar RestrictDateComboItem opens. A relation picker (on / not on / on or before / on or after /
	     between), a start date, and (for "between") an end date, over OK/Cancel. Spec-only modal (OK snapshots
	     the DateRangeFilterPattern into Result). Visible text is localized via FwAvaloniaDialogsStrings (.resx);
	     AutomationIds stay stable + nonlocalized. -->
	<DockPanel>
		<StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
		            HorizontalAlignment="Right" Spacing="{StaticResource DialogButtonStripGap}"
		            Margin="{StaticResource DialogControlGapAbove}">
			<Button Content="{x:Static res:FwAvaloniaDialogsStrings.Ok}" IsDefault="True"
			        Command="{Binding OkCommand}"
			        AutomationProperties.AutomationId="RestrictDate.Ok"/>
			<Button Content="{x:Static res:FwAvaloniaDialogsStrings.Cancel}" IsCancel="True"
			        Command="{Binding CancelCommand}"
			        AutomationProperties.AutomationId="RestrictDate.Cancel"/>
		</StackPanel>

		<StackPanel Spacing="{StaticResource DialogLabelFieldGap}">
			<TextBlock Text="{x:Static res:FwAvaloniaDialogsStrings.RestrictDateRelationLabel}"
			           AutomationProperties.AutomationId="RestrictDate.RelationLabel"/>
			<ComboBox ItemsSource="{Binding MatchTypeLabels}"
			          SelectedIndex="{Binding SelectedMatchTypeIndex}"
			          HorizontalAlignment="Stretch"
			          AutomationProperties.AutomationId="RestrictDate.Relation"
			          AutomationProperties.Name="{x:Static res:FwAvaloniaDialogsStrings.RestrictDateRelationLabel}"/>

			<TextBlock Text="{x:Static res:FwAvaloniaDialogsStrings.RestrictDateDateLabel}"
			           Margin="{StaticResource DialogControlGapAbove}"
			           AutomationProperties.AutomationId="RestrictDate.StartLabel"/>
			<CalendarDatePicker SelectedDate="{Binding StartDate}"
			                    HorizontalAlignment="Stretch"
			                    AutomationProperties.AutomationId="RestrictDate.StartDate"
			                    AutomationProperties.Name="{x:Static res:FwAvaloniaDialogsStrings.RestrictDateDateLabel}"/>

			<TextBlock Text="{x:Static res:FwAvaloniaDialogsStrings.RestrictDateEndLabel}"
			           IsVisible="{Binding ShowEndDate}"
			           Margin="{StaticResource DialogControlGapAbove}"
			           AutomationProperties.AutomationId="RestrictDate.EndLabel"/>
			<CalendarDatePicker SelectedDate="{Binding EndDate}"
			                    IsVisible="{Binding ShowEndDate}"
			                    HorizontalAlignment="Stretch"
			                    AutomationProperties.AutomationId="RestrictDate.EndDate"
			                    AutomationProperties.Name="{x:Static res:FwAvaloniaDialogsStrings.RestrictDateEndLabel}"/>

			<TextBlock Text="{x:Static res:FwAvaloniaDialogsStrings.RestrictDateRangeInverted}"
			           Foreground="Red" TextWrapping="Wrap" Margin="{StaticResource DialogControlGapAbove}"
			           IsVisible="{Binding !IsValid}"
			           AutomationProperties.AutomationId="RestrictDate.ValidationError"/>
		</StackPanel>
	</DockPanel>
</UserControl>
