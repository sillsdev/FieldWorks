<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FwAvaloniaDialogs"
             xmlns:res="clr-namespace:FwAvaloniaDialogs"
             x:Class="FwAvaloniaDialogs.FilterForDialogView"
             x:DataType="vm:FilterForDialogViewModel"
             Classes="fwDialogRoot"
             MinWidth="360" MinHeight="260">
	<!-- The browse "Filter For…" pattern-setup dialog — the Avalonia counterpart of the legacy SimpleMatchDlg
	     the FilterBar FindComboItem opens. A match string, the match-style radios (anywhere/start/end/whole
	     item), a regex checkbox (which disables the position radios), and Match case, over OK/Cancel. Spec-only
	     modal (OK snapshots the FilterForPattern into Result). Visible text is localized via
	     FwAvaloniaDialogsStrings (.resx); AutomationIds stay stable + nonlocalized. -->
	<DockPanel>
		<StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
		            HorizontalAlignment="Right" Spacing="{StaticResource DialogButtonStripGap}"
		            Margin="{StaticResource DialogControlGapAbove}">
			<Button Content="{x:Static res:FwAvaloniaDialogsStrings.Ok}" IsDefault="True"
			        Command="{Binding OkCommand}"
			        AutomationProperties.AutomationId="FilterFor.Ok"/>
			<Button Content="{x:Static res:FwAvaloniaDialogsStrings.Cancel}" IsCancel="True"
			        Command="{Binding CancelCommand}"
			        AutomationProperties.AutomationId="FilterFor.Cancel"/>
		</StackPanel>

		<StackPanel Spacing="{StaticResource DialogLabelFieldGap}">
			<TextBlock Text="{x:Static res:FwAvaloniaDialogsStrings.FilterForMatchLabel}"
			           AutomationProperties.AutomationId="FilterFor.MatchLabel"/>
			<TextBox Text="{Binding MatchText}"
			         AutomationProperties.AutomationId="FilterFor.MatchText"
			         AutomationProperties.Name="{x:Static res:FwAvaloniaDialogsStrings.FilterForMatchLabel}"/>

			<RadioButton GroupName="FilterForMatchStyle"
			             Content="{x:Static res:FwAvaloniaDialogsStrings.FilterForAnywhere}"
			             IsChecked="{Binding MatchAnywhere}" IsEnabled="{Binding PositionOptionsEnabled}"
			             Margin="{StaticResource DialogControlGapAbove}"
			             AutomationProperties.AutomationId="FilterFor.Anywhere"/>
			<RadioButton GroupName="FilterForMatchStyle"
			             Content="{x:Static res:FwAvaloniaDialogsStrings.FilterForAtStart}"
			             IsChecked="{Binding MatchAtStart}" IsEnabled="{Binding PositionOptionsEnabled}"
			             AutomationProperties.AutomationId="FilterFor.AtStart"/>
			<RadioButton GroupName="FilterForMatchStyle"
			             Content="{x:Static res:FwAvaloniaDialogsStrings.FilterForAtEnd}"
			             IsChecked="{Binding MatchAtEnd}" IsEnabled="{Binding PositionOptionsEnabled}"
			             AutomationProperties.AutomationId="FilterFor.AtEnd"/>
			<RadioButton GroupName="FilterForMatchStyle"
			             Content="{x:Static res:FwAvaloniaDialogsStrings.FilterForWholeItem}"
			             IsChecked="{Binding MatchWholeItem}" IsEnabled="{Binding PositionOptionsEnabled}"
			             AutomationProperties.AutomationId="FilterFor.WholeItem"/>

			<!-- Visual separation between the match-style radio group above and the option checkbox group below:
			     a thin grey hairline plus a little extra whitespace, so the two groups read as distinct rather
			     than butting together. -->
			<Border Height="1" Background="{StaticResource DialogGroupSeparatorBrush}"
			        Margin="{StaticResource DialogGroupSeparation}"
			        AutomationProperties.AutomationId="FilterFor.GroupSeparator"/>

			<CheckBox Content="{x:Static res:FwAvaloniaDialogsStrings.FilterForRegex}"
			          IsChecked="{Binding UseRegularExpressions}"
			          AutomationProperties.AutomationId="FilterFor.UseRegex"/>
			<CheckBox Content="{x:Static res:FwAvaloniaDialogsStrings.FilterForMatchCase}"
			          IsChecked="{Binding MatchCase}"
			          AutomationProperties.AutomationId="FilterFor.MatchCase"/>

			<TextBlock Text="{x:Static res:FwAvaloniaDialogsStrings.FilterForInvalidRegex}"
			           Foreground="Red" TextWrapping="Wrap" Margin="{StaticResource DialogControlGapAbove}"
			           IsVisible="{Binding HasInvalidRegex}"
			           AutomationProperties.AutomationId="FilterFor.ValidationError"/>
		</StackPanel>
	</DockPanel>
</UserControl>
