<!--
	DialogTheme — the shared spacing/border system for every FwAvaloniaDialogs dialog body.

	A single source of truth so dialogs cannot regress to "no border / text crowding the edges":
	  * the named spacing TOKENS (below) replace the per-view hardcoded Margin/Spacing literals, and
	  * the STYLES give the injected native-control host borders (the `fwFieldHost` class on the
	    PART_*Host borders) a real default border + padding, and the dialog root (`fwDialogRoot`)
	    a default window padding — applied structurally so a view that omits its own margin still
	    gets breathing room.

	Added to each dialog body's own Styles by DialogThemeBootstrap.Apply(this) (called from every dialog
	view constructor): that both applies these styles to the dialog's control tree and puts the tokens in
	scope so the views' {StaticResource ...} references resolve — in both the runtime host path and the
	headless tests, independent of any application-level resource wiring.
-->
<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<Styles.Resources>
		<!-- Padding around the whole dialog body (between the chrome and the content). -->
		<Thickness x:Key="DialogWindowPadding">10</Thickness>
		<!-- Vertical gap between stacked controls / rows. -->
		<x:Double x:Key="DialogControlGap">6</x:Double>
		<!-- Gap between a field's label and the field itself. -->
		<x:Double x:Key="DialogLabelFieldGap">4</x:Double>
		<!-- Gap between the buttons in an OK/Cancel/Help strip. -->
		<x:Double x:Key="DialogButtonStripGap">8</x:Double>
		<!-- Directional margins derived from the gaps, for the few one-sided spacing needs that Spacing
		     cannot express (a strip docked below content; a prompt above content). -->
		<Thickness x:Key="DialogControlGapAbove">0,6,0,0</Thickness>
		<Thickness x:Key="DialogLabelFieldGapBelow">0,0,0,4</Thickness>
		<!-- Horizontal gutter between two side-by-side regions (e.g. a list and its button column). -->
		<Thickness x:Key="DialogColumnGutter">6,0</Thickness>
		<!-- Small gap below a label sitting directly over its control (the label-field gap, top-only). -->
		<Thickness x:Key="DialogLabelFieldGapAbove">0,2,0,0</Thickness>
		<!-- Inner padding for the content of a tab page (so tab content does not butt the tab border). -->
		<Thickness x:Key="DialogTabContentPadding">6</Thickness>
		<!-- A label-field gap applied above (a label separated from the control above it). -->
		<Thickness x:Key="DialogLabelGroupGapAbove">0,6,0,0</Thickness>
		<!-- Indent + small bottom gap for sub-text under a checkbox/list item. -->
		<Thickness x:Key="DialogSubItemIndent">24,0,0,4</Thickness>
		<!-- Horizontal gap to the right of a leading icon/glyph (message box). -->
		<Thickness x:Key="DialogIconGap">0,0,12,0</Thickness>
		<!-- Visual distance ABOVE a control group that follows another group (e.g. the regex/Match-case
		     checkbox group after the match-style radio group), so distinct groups read as separate rather than
		     butting together. ~8px of extra top whitespace, mirrors FwAvaloniaDensity.GroupSeparation. -->
		<Thickness x:Key="DialogGroupSeparation">0,8,0,0</Thickness>
		<!-- A thin grey 1px hairline drawn BETWEEN two logical groups, for the clearest cases. The brush is a
		     concrete LightGray (not a Fluent DynamicResource) so it renders headlessly. -->
		<SolidColorBrush x:Key="DialogGroupSeparatorBrush" Color="LightGray"/>
		<!-- Minimum height for a compact line control (WinForms ~22px, not the Fluent ~32px floor). -->
		<x:Double x:Key="DialogMinControlHeight">22</x:Double>
		<!-- Border thickness for a host/field frame. -->
		<Thickness x:Key="DialogFieldBorderThickness">1</Thickness>
		<!-- Inner padding for a host/field frame (breathing room around the embedded control). -->
		<Thickness x:Key="DialogFieldPadding">3</Thickness>
		<!-- Base dialog body font (≈ the legacy Segoe UI 9pt WinForms dialog font, vs the ~14px Fluent
		     default). One value drives every TextBox/ComboBox/Button/TextBlock setter below. -->
		<x:Double x:Key="DialogFontSize">12</x:Double>
		<!-- Frame color: a CONCRETE mid-gray that reads as a real input border at the snapshot DPI. A
		     hardcoded value, NOT a Fluent DynamicResource (ControlStrokeColorDefault), because that theme
		     resource does not resolve in the headless test app, so the frame rendered invisible there. -->
		<Color x:Key="DialogFieldBorderColor">#FF7A7A7A</Color>
		<SolidColorBrush x:Key="DialogFieldBorderBrush" Color="#FF7A7A7A"/>
	</Styles.Resources>

	<!-- ============================ DENSITY (font + control height) ============================
	     Setters live HERE (not only in the C# CompactDialogStyles) so the SAME density renders in the
	     headless dialog tests — which apply ONLY this theme via DialogThemeBootstrap.Apply — as at runtime.
	     Values are kept identical to CompactDialogStyles (the runtime chokepoint) so the two never diverge:
	     12px font, ~22px min height, tight WinForms-style paddings, no Fluent min-height floors. -->
	<Style Selector="TextBlock">
		<Setter Property="FontSize" Value="12"/>
	</Style>
	<Style Selector="TextBox">
		<Setter Property="FontSize" Value="12"/>
		<Setter Property="MinHeight" Value="22"/>
		<Setter Property="Padding" Value="4,2"/>
	</Style>
	<Style Selector="ComboBox">
		<Setter Property="FontSize" Value="12"/>
		<Setter Property="MinHeight" Value="22"/>
		<Setter Property="Padding" Value="6,1"/>
	</Style>
	<Style Selector="Button">
		<Setter Property="FontSize" Value="12"/>
		<Setter Property="MinHeight" Value="22"/>
		<Setter Property="Padding" Value="8,2"/>
	</Style>
	<!-- CheckBox FONT only. The deterministic, font-proportional BOX SIZE is applied separately by
	     DialogThemeBootstrap.Apply via the shared C# FwCheckBoxStyle (a ControlTheme that REPLACES the Fluent
	     template — the hardcoded 20×20 box / 32px slot are local values a style setter cannot override). That
	     same helper is the single authority the browse/region lane uses, so checkboxes are one global size. -->
	<Style Selector="CheckBox">
		<Setter Property="FontSize" Value="12"/>
	</Style>
	<Style Selector="TabItem">
		<Setter Property="FontSize" Value="12"/>
		<Setter Property="MinHeight" Value="0"/>
		<Setter Property="Padding" Value="8,3"/>
	</Style>
	<Style Selector="ListBoxItem">
		<Setter Property="MinHeight" Value="0"/>
		<Setter Property="Padding" Value="4,1"/>
	</Style>

	<!-- The dialog root: a default window padding so content never butts against the chrome, even if a
	     view forgets its own margin. The setter value is kept numerically equal to DialogWindowPadding; it
	     is written as a literal (not StaticResource) because a Setter's StaticResource is resolved against
	     the styled element's resource scope, not the enclosing Styles.Resources, so a literal is the reliable
	     way to apply the structural fix. The tokens remain the single source the views bind to. -->
	<Style Selector="UserControl.fwDialogRoot">
		<Setter Property="Padding" Value="10"/>
	</Style>

	<!-- The injected native-control host frame: a real, visible 1px border + inner padding, so the embedded
	     owned control (FwMultiWsTextField / FwOptionPicker) — whose inner TextBox is borderless/transparent —
	     gets a visible WinForms-style input box and breathing room. Structural: any host border carrying the
	     `fwFieldHost` class can't regress to no border. The brush is the CONCRETE gray above (not a Fluent
	     DynamicResource) so the frame renders in the headless tests, not just at runtime. -->
	<Style Selector="Border.fwFieldHost">
		<Setter Property="BorderThickness" Value="1"/>
		<Setter Property="BorderBrush" Value="#FF7A7A7A"/>
		<Setter Property="Padding" Value="3"/>
	</Style>
</Styles>
