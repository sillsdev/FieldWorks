<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>FieldWorks</AssemblyName>
    <RootNamespace>SIL.FieldWorks</RootNamespace>
    <TargetFramework>net48</TargetFramework>
    <OutputType>WinExe</OutputType>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <NoWarn>168,169,219,414,649,1635,1702,1701</NoWarn>
    <!--
      System.Net.Http: .NET Framework 4.8 ships assembly 4.2.0.0, but netstandard NuGet packages
      reference 4.3.4. This is a known platform mismatch resolved at runtime by binding redirects.
      Cannot be fixed at build time. All other projects still fail on MSB3277.
    -->
    <MSBuildWarningsAsMessages>$(MSBuildWarningsAsMessages);MSB3277</MSBuildWarningsAsMessages>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <Deterministic>false</Deterministic>
    <ApplicationIcon>Branding\LT.ico</ApplicationIcon>
    <NoWin32Manifest>true</NoWin32Manifest>
    <EnableRegFreeCom>true</EnableRegFreeCom>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <UseDevTraceConfig Condition="'$(UseDevTraceConfig)'=='' and '$(FW_TRACE_LOG)'!=''">true</UseDevTraceConfig>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>portable</DebugType>
    <Optimize>false</Optimize>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DebugType>portable</DebugType>
    <Optimize>true</Optimize>
    <DefineConstants>TRACE</DefineConstants>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="CommonServiceLocator" Exclude="Build,Analyzers" />
    <PackageReference Include="icu.net" />
    <PackageReference Include="L10NSharp" />
    <PackageReference Include="mixpanel-csharp" />
    <PackageReference Include="SharpZipLib" Exclude="Build,Analyzers" />
    <PackageReference Include="SIL.Core" />
    <PackageReference Include="SIL.Core.Desktop" />
    <PackageReference Include="SIL.DesktopAnalytics" />
    <PackageReference Include="SIL.LCModel" />
    <PackageReference Include="SIL.LCModel.Core" GeneratePathProperty="true" />
    <PackageReference Include="SIL.LCModel.Utils" />
    <PackageReference Include="SIL.Lexicon" />
    <PackageReference Include="SIL.ParatextShared" />
    <PackageReference Include="SIL.Windows.Forms" />
    <PackageReference Include="SIL.Windows.Forms.Keyboarding" />
    <PackageReference Include="SIL.WritingSystems" />
    <PackageReference Include="Geckofx60.64" />
  </ItemGroup>
  <ItemGroup>
    <Reference Include="Microsoft.Build.Framework" />
    <Reference Include="PaToFdoInterfaces">
      <HintPath>..\..\..\DistFiles\PaToFdoInterfaces.dll</HintPath>
    </Reference>
    <Reference Include="System.Configuration" />
    <Reference Include="System.Drawing" />
    <Reference Include="System.Net" />
    <Reference Include="System.Runtime.Remoting" />
    <Reference Include="System.Runtime.Serialization" />
    <Reference Include="System.ServiceModel" />
    <Reference Include="System.Windows.Forms" />
    <Reference Include="netstandard" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="../../FdoUi/FdoUi.csproj" />
    <ProjectReference Include="../../FwCoreDlgs/FwCoreDlgs.csproj" />
    <ProjectReference Include="../../FwResources/FwResources.csproj" />
    <ProjectReference Include="../../LexText/LexTextDll/LexTextDll.csproj" />
    <ProjectReference Include="../../Utilities/Reporting/Reporting.csproj" />
    <ProjectReference Include="../../Utilities/XMLUtils/XMLUtils.csproj" />
    <ProjectReference Include="../../XCore/xCoreInterfaces/xCoreInterfaces.csproj" />
    <ProjectReference Include="../../xWorks/xWorks.csproj" />
    <ProjectReference Include="../Controls/FwControls/FwControls.csproj" />
    <ProjectReference Include="../Framework/Framework.csproj" />
    <ProjectReference Include="../FwUtils/FwUtils.csproj" />
    <ProjectReference Include="../RootSite/RootSite.csproj" />
    <ProjectReference Include="../ScriptureUtils/ScriptureUtils.csproj" />
    <ProjectReference Include="../SimpleRootSite/SimpleRootSite.csproj" />
    <ProjectReference Include="../ViewsInterfaces/ViewsInterfaces.csproj" />
    <ProjectReference Include="..\..\LexText\LexTextControls\LexTextControls.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="..\..\CommonAssemblyInfo.cs">
      <Link>Properties\CommonAssemblyInfo.cs</Link>
    </Compile>
    <EmbeddedResource Update="Properties\Resources.resx" />
    <Compile Remove="FieldWorksTests/**" />
    <None Remove="FieldWorksTests/**" />
  </ItemGroup>
  <ItemGroup>
    <None Include="Branding\LT.ico" />
    <None Include="Branding\LT.png" />
    <None Include="Branding\LT64.png" />
    <None Include="Branding\LT128.png" />
    <None Include="FieldWorks.Diagnostics.config" Condition="'$(UseDevTraceConfig)'!='true'">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="FieldWorks.Diagnostics.dev.config" Condition="'$(UseDevTraceConfig)'=='true'">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      <TargetPath>FieldWorks.Diagnostics.config</TargetPath>
    </None>
  </ItemGroup>
  <Import Project="BuildInclude.targets" />
  <ItemGroup>
    <EmbeddedResource Include="BookAndCube.ico" />
    <EmbeddedResource Include="BookOnCube.ico" />
    <EmbeddedResource Include="BookOnCubeVersion.ico" />
    <EmbeddedResource Include="CubeOnBook.ico" />
    <EmbeddedResource Include="CubeOnBookVersion.ico" />
    <EmbeddedResource Include="LargeCubeOnBook.ico" />
    <EmbeddedResource Include="LargeCubeOnBookVersion.ico" />
    <EmbeddedResource Include="SmallBookOnCube.ico" />
    <EmbeddedResource Include="SmallBookOnCubeVersion.ico" />
  </ItemGroup>
</Project>