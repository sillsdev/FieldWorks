<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup useLegacyV2RuntimeActivationPolicy="true">
<supportedRuntime version="v4.0" />
  </startup>
<system.diagnostics configSource="FieldWorks.Diagnostics.config" />
  <runtime>
<generatePublisherEvidence enabled="false" />
<assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
<!--
Binding redirects are auto-generated at build time
(AutoGenerateBindingRedirects=true in Directory.Build.props).
Do NOT add manual redirects here; they override auto-gen and will drift
from CPM-pinned versions in Directory.Packages.props.

Only entries that auto-gen cannot produce are kept below.
-->

<!-- codeBase hint: some dependencies reference SIL.Core.Desktop version 0.0.0.0.
 Auto-gen does not produce codeBase elements.
 Remove when ParatextData and FieldWorks libpalaso versions converge. -->
<dependentAssembly>
<assemblyIdentity name="SIL.Core.Desktop" publicKeyToken="cab3c8c5232dfcf2" culture="neutral" />
<codeBase version="0.0.0.0" href="SIL.Core.Desktop.dll" />
</dependentAssembly>
<!-- Chorus 6.0.0 references L10NSharp 9.0.0; redirect to 10.0.0.
     Remove when Chorus is updated to reference L10NSharp 10. -->
<dependentAssembly>
<assemblyIdentity name="L10NSharp" publicKeyToken="fd0b3e309a5b7c28" culture="neutral" />
<bindingRedirect oldVersion="0.0.0.0-10.0.0.0" newVersion="10.0.0.0" />
</dependentAssembly>
</assemblyBinding>
  </runtime>
</configuration>
