<?xml version='1.0' encoding='utf-8'?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>xWorksTests</AssemblyName>
    <RootNamespace>SIL.FieldWorks.XWorks</RootNamespace>
    <TargetFramework>net48</TargetFramework>
    <OutputType>Library</OutputType>    <!-- AVA2001: see xWorks.csproj — the compile-only Avalonia reference drags the analyzer along. -->
    <NoWarn>168,169,219,414,649,1635,1702,1701,NU1903,AVA2001</NoWarn>
    <IsTestProject>true</IsTestProject>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <Prefer32Bit>false</Prefer32Bit>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|x64' ">
    <DefineConstants>DEBUG</DefineConstants>
    <DebugSymbols>true</DebugSymbols>
    <Optimize>false</Optimize>
    <DebugType>portable</DebugType>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|x64' ">
    <DefineConstants>TRACE</DefineConstants>
    <DebugSymbols>true</DebugSymbols>
    <Optimize>true</Optimize>
    <DebugType>portable</DebugType>
  </PropertyGroup>
  <ItemGroup>
    <!-- Compile-only (PrivateAssets): fake IRegionEditorPlugin implementations in
         LexemeEditorBurnDownTests name Avalonia.Controls.Control (winforms-free-lexeme-editor.md
         D1); the runtime assemblies are already in the shared output via FwAvalonia. -->
    <PackageReference Include="Avalonia" IncludeAssets="compile" PrivateAssets="all" />
    <!-- Avalonia's transitive analyzer carrier; IncludeAssets="none" keeps the AVA* analyzers out. -->
    <PackageReference Include="Avalonia.BuildServices" IncludeAssets="none" PrivateAssets="all" />
    <!-- Headless Avalonia platform for the assembly-level SetUpFixture (AvaloniaHeadlessSetUpFixture):
         integration tests that drive the product surface (RecordEditView/RecordBrowseView host the
         Avalonia region/browse surface) otherwise initialize the REAL Win32 Avalonia platform
         process-wide, so any flyout/dialog/popup becomes a real on-screen window that flashes and can
         steal keypresses. The fixture installs a headless builder (matching FwAvaloniaTests) before any
         test runs. Headless is test-only here; the production FwAvalonia DLL stays Headless-free. -->
    <PackageReference Include="Avalonia.Headless" ExcludeAssets="analyzers" PrivateAssets="all" />
    <PackageReference Include="Avalonia.Skia" ExcludeAssets="analyzers" PrivateAssets="all" />
    <PackageReference Include="CommonServiceLocator" Exclude="Build,Analyzers" />
    <!-- D2: ChorusNotesContractTests read notes back through real LibChorus repositories. -->
    <PackageReference Include="SIL.Chorus.LibChorus" />
    <!-- TestLocalizationManagerBootstrap registers a minimal English LocalizationManager so the
         legacy lexicon DataTree's MessageSlice (Chorus NotesBar) can localize headlessly, the same
         way FieldWorks.InitializeLocalizationManager does at app startup. The L10NSharp package
         ships both L10NSharp.dll and L10NSharp.Windows.Forms.dll. -->
    <PackageReference Include="L10NSharp" />
    <PackageReference Include="DocumentFormat.OpenXml" />
    <PackageReference Include="ProDotNetZip" />
    <PackageReference Include="icu.net" />
    <PackageReference Include="Newtonsoft.Json" />
    <PackageReference Include="SIL.Core" />
    <PackageReference Include="SIL.Core.Desktop" />
    <PackageReference Include="SIL.LCModel" />
    <PackageReference Include="SIL.LCModel.Core" GeneratePathProperty="true" />
    <PackageReference Include="SIL.LCModel.Core.Tests" PrivateAssets="All" />
    <PackageReference Include="SIL.LCModel.Tests" PrivateAssets="All" />
    <PackageReference Include="SIL.LCModel.Utils" />
    <PackageReference Include="SIL.LCModel.Utils.Tests" PrivateAssets="All" />
    <PackageReference Include="SIL.TestUtilities" />
    <PackageReference Include="SIL.WritingSystems" />
    <PackageReference Include="SIL.ExCSS" />
  </ItemGroup>
  <ItemGroup>
    <Reference Include="Microsoft.CSharp" />
    <Reference Include="System" />
    <Reference Include="System.Core" />
    <Reference Include="System.Drawing" />
    <Reference Include="System.Windows.Forms" />
    <Reference Include="UIAutomationClient" />
    <Reference Include="UIAutomationTypes" />
    <Reference Include="System.Xml.Linq" />
    <Reference Include="netstandard" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="../../Common/Controls/FwControls/FwControls.csproj" />
    <ProjectReference Include="../../Common/Controls/Widgets/Widgets.csproj" />
    <ProjectReference Include="../../Common/Controls/XMLViews/XMLViews.csproj" />
    <ProjectReference Include="../../Common/Filters/Filters.csproj" />
    <ProjectReference Include="../../Common/Framework/Framework.csproj" />
    <ProjectReference Include="../../Common/FwUtils/FwUtils.csproj" />
    <ProjectReference Include="../../Common/FwUtils/FwUtilsTests/FwUtilsTests.csproj" />
    <ProjectReference Include="../../Common/RootSite/RootSite.csproj" />
    <ProjectReference Include="../../Common/SimpleRootSite/SimpleRootSite.csproj" />
    <ProjectReference Include="../../Common/ViewsInterfaces/ViewsInterfaces.csproj" />
    <ProjectReference Include="../../FwCoreDlgs/FwCoreDlgControls/FwCoreDlgControls.csproj" />
    <ProjectReference Include="../../FwCoreDlgs/FwCoreDlgs.csproj" />
    <ProjectReference Include="../../LexText/Lexicon/LexEdDll.csproj" />
    <ProjectReference Include="../../Utilities/XMLUtils/XMLUtils.csproj" />
    <ProjectReference Include="../../XCore/xCore.csproj" />
    <ProjectReference Include="../../XCore/xCoreInterfaces/xCoreInterfaces.csproj" />
    <ProjectReference Include="../xWorks.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="..\..\CommonAssemblyInfo.cs">
      <Link>Properties\CommonAssemblyInfo.cs</Link>
    </Compile>
  </ItemGroup>
</Project>