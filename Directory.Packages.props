		<PackageVersion Include="SIL.Chorus.LibChorus" Version="6.0.0-beta0063" />
		<PackageVersion Include="SIL.DesktopAnalytics" Version="4.0.0" />
		<PackageVersion Include="SIL.ExCSS" Version="2.0.2" />
		<PackageVersion Include="SIL.FLExBridge.IPCFramework" Version="1.1.1-beta0001" />
