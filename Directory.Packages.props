<Project>
	<PropertyGroup>
		<ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
		<!--
			Floating Versions: Allow floating pre-release versions like 11.0.0-* and 17.0.0-*
			used by SIL LCModel and LibPalaso ecosystem packages.
			Requires NuGet 6.4+ / .NET SDK 7.0.200+.
		-->
		<CentralPackageFloatingVersionsEnabled>true</CentralPackageFloatingVersionsEnabled>
		<!--
			Transitive Pinning: When a package is declared here but only consumed
			transitively (not directly referenced by a project), NuGet still pins it
			to the version below. This prevents the "last writer wins" problem in our
			shared Output/ directory, which is the root cause of assembly-version
			mismatch crashes like System.Drawing.Common 9.0 vs 6.0 (LT-22382 class).
		-->
		<CentralPackageTransitivePinningEnabled>true</CentralPackageTransitivePinningEnabled>
	</PropertyGroup>

	<!--
		=============================================================
		TRANSITIVE PINS
		Packages not directly referenced by any project, but whose
		transitive versions must be forced to a single value across
		all projects sharing Output/{Configuration}/.
		=============================================================
	-->
	<ItemGroup Label="Transitive Pins">
		<!-- System.Drawing.Common: SIL.LCModel.Core pulls 6.0.0 transitively,
		     but ParatextData 9.5.x requires >= 9.0.9. Pin to 9.0.9. -->
		<PackageVersion Include="System.Drawing.Common" Version="9.0.9" />
		<!-- System.Resources.Extensions: required for non-string resources (images, icons)
		     in .NET Framework SDK-style projects. -->
		<PackageVersion Include="System.Resources.Extensions" Version="9.0.0" />
		<!-- DependencyModel: icu.net wants 2.0.4, ParatextData wants 9.0.9.
		     9.0.9 is backward compatible with 2.0.4 API surface. -->
		<PackageVersion Include="Microsoft.Extensions.DependencyModel" Version="9.0.9" />
		<!-- System.Memory: ParatextData requires 4.6.3; other packages want 4.5.0–4.6.0. -->
		<PackageVersion Include="System.Memory" Version="4.6.3" />
		<!-- Microsoft.Bcl.HashCode: System.Resources.Extensions 9.0.0 requires HashCode. -->
		<PackageVersion Include="Microsoft.Bcl.HashCode" Version="6.0.0" />
		<!-- System.Security.Permissions (LT-22394): ProDotNetZip needs >= 8.0.0,
		     System.Security.AccessControl needs >= 6.0.0. Pin to 9.0.9. -->
		<PackageVersion Include="System.Security.Permissions" Version="9.0.9" />
	</ItemGroup>

	<!--
		=============================================================
		SIL LCModel Ecosystem (floating pre-release)
		=============================================================
	-->
	<ItemGroup Label="SIL LCModel Ecosystem">
		<PackageVersion Include="SIL.LCModel" Version="11.0.0-*" />
		<PackageVersion Include="SIL.LCModel.Core" Version="11.0.0-*" />
		<PackageVersion Include="SIL.LCModel.Core.Tests" Version="11.0.0-*" />
		<PackageVersion Include="SIL.LCModel.FixData" Version="11.0.0-*" />
		<PackageVersion Include="SIL.LCModel.Tests" Version="11.0.0-*" />
		<PackageVersion Include="SIL.LCModel.Utils" Version="11.0.0-*" />
		<PackageVersion Include="SIL.LCModel.Utils.Tests" Version="11.0.0-*" />
	</ItemGroup>

	<!--
		=============================================================
		SIL LibPalaso Ecosystem (floating pre-release)
		=============================================================
	-->
	<ItemGroup Label="SIL LibPalaso Ecosystem">
		<PackageVersion Include="SIL.Core" Version="17.0.0-*" />
		<PackageVersion Include="SIL.Core.Desktop" Version="17.0.0-*" />
		<PackageVersion Include="SIL.Archiving" Version="17.0.0-*" />
		<PackageVersion Include="SIL.Lexicon" Version="17.0.0-*" />
		<PackageVersion Include="SIL.Lift" Version="17.0.0-*" />
		<PackageVersion Include="SIL.Media" Version="17.0.0-*" />
		<PackageVersion Include="SIL.Scripture" Version="17.0.0-*" />
		<PackageVersion Include="SIL.TestUtilities" Version="17.0.0-*" />
		<PackageVersion Include="SIL.Windows.Forms" Version="17.0.0-*" />
		<PackageVersion Include="SIL.Windows.Forms.Archiving" Version="17.0.0-*" />
		<PackageVersion Include="SIL.Windows.Forms.GeckoBrowserAdapter" Version="17.0.0-*" />
		<PackageVersion Include="SIL.Windows.Forms.Keyboarding" Version="17.0.0-*" />
		<PackageVersion Include="SIL.Windows.Forms.WritingSystems" Version="17.0.0-*" />
		<PackageVersion Include="SIL.WritingSystems" Version="17.0.0-*" />
		<!-- Pinned version used by FwCoreDlgsTests only -->
		<PackageVersion Include="SIL.WritingSystems.Tests" Version="15.0.0-beta0117" />
	</ItemGroup>

	<!--
		=============================================================
		SIL Localization (ExcludeAssets=all; consumed by Build/Localize.targets)
