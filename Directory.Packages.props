	<ItemGroup Label="SIL Localization">
		<PackageVersion Include="L10NSharp" Version="9.0.0-*" />
		<PackageVersion Include="SIL.Chorus.L10ns" Version="3.0.1" />
		<PackageVersion Include="SIL.LibPalaso.L10ns" Version="17.0.0-*" />
	</ItemGroup>

	<!--
