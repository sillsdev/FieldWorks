{
  "servers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide",
        "--project",
        "${workspaceFolder}"
      ],
      "env": {
        "SERENA_API_KEY": "${env:SERENA_API_KEY}"
      }
    },
    "winforms-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@fnrhombus/winforms-mcp"
      ],
      "env": {
        "HEADLESS": "true",
        "TFM": "net48",
        "TELEMETRY_OPTOUT": "true"
      }
    }
  }
}